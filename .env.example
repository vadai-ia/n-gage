# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Base de datos (Supabase PostgreSQL) ────────────────────
# Importante: URL-encode los caracteres especiales en la contraseña
# # → %23   & → %26   @ → %40
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres

# ─── Cloudinary (fotos y selfies) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Resend (emails transaccionales) ────────────────────────
RESEND_API_KEY=re_your-api-key
# Recomendado: usar un subdominio dedicado (ej. automail.tudominio.com)
# para aislar DNS de email del dominio principal.
RESEND_FROM_EMAIL=noreply@automail.your-domain.com

# ─── Google OAuth (via Supabase) ────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
